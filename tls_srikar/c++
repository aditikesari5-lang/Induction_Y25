class Account
{
protected:
    long accountNumber;
    string accountType;
    double balance;
    string dateOpened;

public:
    string status;
    Branch *branch;
    Customer *customer;

    vector<Transaction *> transactions;

    virtual void deposit(double amount) = 0;
    virtual void withdraw(double amount) = 0;
};
class SavingsAccount : public Account
{
public:
    double interestRate;
    double minimumBalance;

    void deposit(double amount) override
    {
        balance = balance + amount;
    }

    void withdraw(double amount) override
    {
        if (status == "blocked")
        {
            throw AccountBlockedException();
        }
        if (balance < amount)
        {
            throw InsufficientBalanceException();
        }
        if (balance - amount < minimumBalance)
        {
            throw InsufficientBalanceException();
        }
        balance -= amount;
    }
};

class CurrentAccount : public Account
{
public:
    double overdraftLimit;
    string businessName;

    void deposit(double amount) override
    {
        balance = balance + amount;
    }
    void withdraw(double amount) override
    {
        if (status == "blocked")
        {
            throw AccountBlockedException();
        }
        if (balance + overdraftLimit < amount)
        {
            throw InsufficientBalanceException();
        }
        balance -= amount;
    }
};

class FixedDepositAccount : public Account
{
public:
    double FDAmount;
    string maturityDate;
    double FDInterestRate;
    int tenureMonths;

public:
    void deposit(double amount) override
    {
        FDAmount = amount;
        balance = FDAmount + (FDAmount * FDInterestRate / 100 * tenureMonths / 12);
    }
    void withdraw(double amount) override
    {
        throw InsufficientBalanceException();
    }
};

class Transaction
{
protected:
    int transactionId;

public:
    string transactionType;
    double amount;
    string transactionDate;
    Account *senderAccount;
    Account *receiverAccount;
    string status;
};

class Loan
{
protected:
    int loanId;
    string loanType;
    double loanAmount;

public:
    double interestRate;
    int tenureYears;
    double EMIAmount;
    string loanStatus;
    Customer *customer;
    void emi()
    {
        int n = 12 * tenureYears;
        double p = loanAmount;
        double r = (interestRate / 12) / 100;
        EMIAmount = (p * r * pow(1 + r, n)) / (pow(1 + r, n) - 1);
    }
};

